// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id   String @id @default(cuid())
  slug String @unique // URL slug: "acme-corp" — used in fallback path URL
  name String // Display name: "Acme Corporation"

  // "AGENCY" | "CLIENT"
  type String @default("CLIENT")

  // Primary domain — their website
  domain String? @unique // "acme-corp.com" — optional if not yet known

  // Admin subdomain (optional — set when DNS is configured by client)
  subdomain String? @unique // "admin.acme-corp.com"

  // Branding
  logoUrl     String?
  accentColor String  @default("#6366F1")

  // CRM link — the CRM site record this tenant is linked to
  crmSiteId String? @unique

  // Sanity dataset
  sanityDataset String @default("production")

  // Relations
  users PortalUser[]
  featureFlags TenantFeatureFlag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortalUser {
  id       String  @id @default(cuid())
  email    String
  name     String?
  // Hashed password — null if user has not set a password yet (magic-link-only users)
  password String?

  // "OWNER" | "EDITOR" | "BILLING" | "SUPPORT"
  role String @default("EDITOR")

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Track if user has completed first-time setup (password + profile)
  hasCompletedOnboarding Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth v5 required relation
  accounts Account[]
  Session  Session[]

  @@unique([email, tenantId])
}

// NextAuth v5 requires these tables for Account/Session management (OAuth + magic link)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user PortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String     @id @default(cuid())
  sessionToken String     @unique
  userId       String
  expires      DateTime
  user         PortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id       String   @id @default(cuid())
  email    String
  tenantId String? // Scopes magic link invites to a specific tenant
  token    String   @unique
  expires  DateTime

  @@unique([email, token])
}

// ─── Feature Flags ─────────────────────────────────────────────────────────────

// Registry of all available feature flags (defined in code, seeded to DB)
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique // "studio", "support", "billing", etc.
  label       String            // "Site Editor", "Support Tickets", etc.
  description String?
  isBeta      Boolean  @default(false)

  // Relations
  tenants TenantFeatureFlag[]

  createdAt DateTime @default(now())
}

// Per-tenant feature flag override — null means "use default" (usually false)
model TenantFeatureFlag {
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  featureFlagId String
  featureFlag  FeatureFlag @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)
  enabled      Boolean @default(false) // true = flag is ON for this tenant

  @@id([tenantId, featureFlagId])
}
